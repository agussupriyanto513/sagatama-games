{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/pi-auth.js": {
      "maxDuration": 30
    },
    "api/payments/approve.js": {
      "maxDuration": 10
    },
    "api/payments/complete.js": {
      "maxDuration": 30
    },
    "api/payments/cancel.js": {
      "maxDuration": 10
    },
    "api/payments/incomplete.js": {
      "maxDuration": 30
    },
    "api/payments/payout.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/pi-auth",               "dest": "/api/pi-auth.js" },
    { "src": "/api/pi-payment/approve",    "dest": "/api/payments/approve.js" },
    { "src": "/api/pi-payment/complete",   "dest": "/api/payments/complete.js" },
    { "src": "/api/pi-payment/cancel",     "dest": "/api/payments/cancel.js" },
    { "src": "/api/pi-payment/incomplete", "dest": "/api/payments/incomplete.js" },
    { "src": "/api/pi-payment/payout",    "dest": "/api/payments/payout.js" },
    { "src": "/validation-key.txt",     "dest": "/validation-key.txt" },
    { "src": "/.well-known/(.*)",          "dest": "/.well-known/$1" },
    { "src": "/",                          "dest": "/SAGATAMA-GAMES.html" },
    { "src": "/games",                     "dest": "/SAGATAMA-GAMES.html" },
    { "src": "/terms",                     "dest": "/terms-privacy.html" },
    { "src": "/(.*)\\.html",               "dest": "/$1.html" },
    { "src": "/(.*)",                      "dest": "/$1" }
  ]
}
