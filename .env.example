# ============================================
# SAGATAMA ECOSYSTEM — Environment Variables
# ============================================
# JANGAN isi file ini dengan nilai asli!
# Copy file ini jadi .env lalu isi nilainya.
# File .env TIDAK boleh di-push ke GitHub.
# ============================================

# Firebase Admin SDK
# Ambil dari: Firebase Console → Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=sagatama-ecosystem
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sagatama-ecosystem.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxxxx\n-----END PRIVATE KEY-----\n"

# Pi Network API Key
# Ambil dari: Pi Developer Portal → My Apps → API Keys
PI_API_KEY=your_pi_api_key_here
